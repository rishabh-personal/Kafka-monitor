# Copy this to .env for local development
# Set these as Environment Variables in DigitalOcean App Platform

# UI protection (required for production)
UI_PASSWORD=admin@123###
SESSION_SECRET=your-random-secret-at-least-32-chars

KAFKA_UI_URL=https://kafka-ui.prod.zwing.in
CLUSTER_NAME=central-zwing
SLACK_WEBHOOK=your-slack-incoming-webhook-url
APP_URL=https://your-app.ondigitalocean.app
CHECK_INTERVAL=*/15 * * * *
LAG_THRESHOLD=10000
CHECK_PARTITION_BALANCE=true
PORT=3000
